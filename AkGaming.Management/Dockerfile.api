FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS base
WORKDIR /app
EXPOSE 3011

FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src

# Copy everything
COPY . ./

# Restore solution
RUN dotnet restore /src/AkGaming.Management.sln

# Build
RUN dotnet build /src/WebApi/AkGaming.Management.WebApi.csproj -c Release -o /app/build

FROM build AS publish
RUN dotnet publish /src/WebApi/AkGaming.Management.WebApi.csproj -c Release -o /app/publish /p:UseAppHost=false

FROM base AS final
WORKDIR /app
COPY --from=publish /app/publish .
ENTRYPOINT ["dotnet", "AkGaming.Management.WebApi.dll"]
