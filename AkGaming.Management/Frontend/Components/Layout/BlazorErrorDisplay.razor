<div id="blazor-error-ui" data-nosnippet role="alert" aria-live="assertive" aria-atomic="true">
    <div class="error-card">
        <div class="error-card-header">
            <div class="error-card-brand">
                <div class="error-card-icon" aria-hidden="true">
                    <span class="bi bi-exclamation-octagon"></span>
                </div>
                <div>
                    <p class="error-card-eyebrow">AK Gaming Management</p>
                    <h2 class="error-card-title">Unexpected client error</h2>
                </div>
            </div>

            <button type="button"
                    class="dismiss error-card-close"
                    aria-label="Dismiss error message"
                    onclick="document.getElementById('blazor-error-ui').style.display='none'">
                <span class="bi bi-x-lg" aria-hidden="true"></span>
            </button>
        </div>

        <div class="error-card-body">
            <p class="error-card-message">The current page hit an unexpected error and may no longer respond correctly.</p>
            <p class="error-card-subtle">Reload the page to restore a clean session. If the issue keeps happening, check the browser console and server logs.</p>

            <div class="error-card-actions">
                <a href="." class="reload btn btn-primary">Reload page</a>
            </div>
        </div>
    </div>
</div>
