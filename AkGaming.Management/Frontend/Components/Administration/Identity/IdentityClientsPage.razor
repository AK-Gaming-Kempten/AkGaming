@page "/identity/clients"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]

<PageTitle>Identity Clients</PageTitle>

<div class="ui-stack-md identity-admin-page">
    <section class="panel identity-admin-card">
        <div class="identity-admin-toolbar">
            <h4 class="ui-title">OIDC Clients</h4>
            <div class="ui-actions">
                <button class="btn btn-sm btn-secondary" @onclick="ReloadAsync" disabled="@_isBusy">Refresh</button>
                <button type="button"
                        class="btn btn-sm btn-outline-secondary"
                        @onclick="ToggleCreateForm">
                    @(_showCreateForm ? "Hide create client" : "Create client")
                </button>
            </div>
        </div>

        @if (_showCreateForm)
        {
            <div class="ui-divider-top-dashed identity-create-form">
                <div class="ui-grid-auto-180">
                    <div class="ui-field">
                        <label for="new-client-id">Client id</label>
                        <InputText id="new-client-id" @bind-Value="_newClientId" placeholder="frontend-app" />
                    </div>

                    <div class="ui-field">
                        <label for="new-display-name">Display name</label>
                        <InputText id="new-display-name" @bind-Value="_newDisplayName" placeholder="Frontend App" />
                    </div>

                    <div class="ui-field">
                        <label for="new-client-type">Client type</label>
                        <InputSelect id="new-client-type" @bind-Value="_newClientType">
                            <option value="confidential">confidential</option>
                            <option value="public">public</option>
                        </InputSelect>
                    </div>

                    <div class="ui-field">
                        <label for="new-consent-type">Consent type</label>
                        <InputSelect id="new-consent-type" @bind-Value="_newConsentType">
                            <option value="implicit">implicit</option>
                            <option value="explicit">explicit</option>
                            <option value="external">external</option>
                            <option value="systematic">systematic</option>
                        </InputSelect>
                    </div>
                </div>

                @if (string.Equals(_newClientType, "confidential", StringComparison.OrdinalIgnoreCase))
                {
                    <div class="ui-field">
                        <label for="new-client-secret">Client secret</label>
                        <InputText id="new-client-secret" @bind-Value="_newClientSecret" placeholder="Leave empty to generate without a secret" />
                    </div>
                }

                <div class="identity-grid-wide">
                    <div class="ui-field">
                        <label for="new-client-redirects">Redirect URIs</label>
                        <InputTextArea id="new-client-redirects" @bind-Value="_newRedirectUrisText" placeholder="One URI per line" />
                    </div>

                    <div class="ui-field">
                        <label for="new-client-post-logout-redirects">Post logout redirect URIs</label>
                        <InputTextArea id="new-client-post-logout-redirects" @bind-Value="_newPostLogoutRedirectUrisText" placeholder="One URI per line" />
                    </div>

                    <div class="ui-field">
                        <label for="new-client-scopes">Scopes</label>
                        <InputTextArea id="new-client-scopes" @bind-Value="_newScopesText" placeholder="One scope per line" />
                    </div>
                </div>

                <div class="identity-create-options">
                    <label class="role-checkbox">
                        <InputCheckbox @bind-Value="_newRequirePkce" />
                        <span>Require PKCE</span>
                    </label>
                    <label class="role-checkbox">
                        <InputCheckbox @bind-Value="_newAllowRefreshTokenFlow" />
                        <span>Allow refresh token flow</span>
                    </label>
                </div>

                <div class="ui-actions">
                    <button class="btn btn-sm btn-primary" @onclick="CreateClientAsync" disabled="@_isBusy">Create client</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ToggleCreateForm" disabled="@_isBusy">Cancel</button>
                </div>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <p class="text-danger">@_error</p>
        }

        @if (!string.IsNullOrWhiteSpace(_success))
        {
            <p class="text-success">@_success</p>
        }
    </section>

    <section class="panel identity-admin-card">
        <h4 class="ui-title">Existing Clients</h4>

        @if (_clients is null)
        {
            <p>Loading clients...</p>
        }
        else if (_clients.Count == 0)
        {
            <p>No clients found.</p>
        }
        else
        {
            <div class="ui-list identity-entry-list">
                @foreach (var client in SortedClients)
                {
                    <IdentityClientEntry @key="client.ClientId"
                                         Client="client"
                                         IsBusy="_isBusy"
                                         OnSave="SaveClientAsync"
                                         OnDelete="DeleteClientAsync" />
                }
            </div>
        }
    </section>
</div>
