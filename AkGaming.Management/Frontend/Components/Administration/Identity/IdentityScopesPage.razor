@page "/identity/scopes"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]

<PageTitle>Identity Scopes</PageTitle>

<div class="ui-stack-md identity-admin-page">
    <section class="panel identity-admin-card">
        <div class="identity-admin-toolbar">
            <h4 class="ui-title">OIDC Scopes</h4>
            <div class="ui-actions">
                <button class="btn btn-sm btn-secondary" @onclick="ReloadAsync" disabled="@_isBusy">Refresh</button>
                <button type="button"
                        class="btn btn-sm btn-outline-secondary"
                        @onclick="ToggleCreateForm">
                    @(_showCreateForm ? "Hide create scope" : "Create scope")
                </button>
            </div>
        </div>

        @if (_showCreateForm)
        {
            <div class="ui-divider-top-dashed identity-create-form">
                <div class="ui-grid-auto-180">
                    <div class="ui-field">
                        <label for="new-scope-name">Scope name</label>
                        <InputText id="new-scope-name" @bind-Value="_newScopeName" placeholder="akgaming.api" />
                    </div>

                    <div class="ui-field">
                        <label for="new-scope-display-name">Display name</label>
                        <InputText id="new-scope-display-name" @bind-Value="_newDisplayName" placeholder="AK Gaming API" />
                    </div>
                </div>

                <div class="ui-field">
                    <label for="new-scope-description">Description</label>
                    <InputTextArea id="new-scope-description" @bind-Value="_newDescription" placeholder="Describe what the scope grants access to" />
                </div>

                <div class="ui-field">
                    <label for="new-scope-resources">Resources</label>
                    <InputTextArea id="new-scope-resources" @bind-Value="_newResourcesText" placeholder="One resource per line" />
                </div>

                <div class="ui-actions">
                    <button class="btn btn-sm btn-primary" @onclick="CreateScopeAsync" disabled="@_isBusy">Create scope</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ToggleCreateForm" disabled="@_isBusy">Cancel</button>
                </div>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <p class="text-danger">@_error</p>
        }

        @if (!string.IsNullOrWhiteSpace(_success))
        {
            <p class="text-success">@_success</p>
        }
    </section>

    <section class="panel identity-admin-card">
        <h4 class="ui-title">Existing Scopes</h4>

        @if (_scopes is null)
        {
            <p>Loading scopes...</p>
        }
        else if (_scopes.Count == 0)
        {
            <p>No scopes found.</p>
        }
        else
        {
            <div class="ui-list identity-entry-list">
                @foreach (var scope in SortedScopes)
                {
                    <IdentityScopeEntry @key="scope.Name"
                                        Scope="scope"
                                        IsBusy="_isBusy"
                                        OnSave="SaveScopeAsync"
                                        OnDelete="DeleteScopeAsync" />
                }
            </div>
        }
    </section>
</div>
