@page "/member-management"
<PageTitle>Member Management</PageTitle>
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@inject HttpClient Api

<div class="two-column-layout">
    <div class="two-column-layout-left">
        <div class="list-buttons">
            <h4>Existing Members</h4>
            <button class="btn btn-secondary" @onclick="OpenFilters" disabled="@true">Filters</button>
            <button class="btn btn-primary" @onclick="CreateMember">Create Member</button>
        </div>
        <div class="list-main">
            @if (_members == null)
            {
                <p>Loading…</p>
            }
            else if (!_members.Any())
            {
                <p>No members found.</p>
            }
            else
            {
                <div class="list-scroll-container">
                    <div class="preview-card-list">
                        @foreach (var member in _members)
                        {
                            <MemberPreviewCard Member="member" IsSelected="member == _selectedMember" OnSelect="SelectMember"/>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
    <div class="two-column-layout-right">
        <CascadingValue Value="MemberApi" Name="MemberManagementApi" IsFixed="true">
            <MemberCard Member="_selectedMember" IsEditable="true" IsStatusEditable="true" OnMemberUpdated="Reload" />
            @if (_createError != null)
            {
                <p class="text-danger">@_createError</p>
            }
        </CascadingValue>  
    </div>
</div>