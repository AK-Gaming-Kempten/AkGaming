@inject HttpClient Api

<div class="two-column-layout mobile-master-detail @(_isMobileDetailOpen ? "mobile-detail-open" : string.Empty)">
    <div class="two-column-layout-left">
        <div class="list-buttons">
            <h4>Pending Requests</h4>
            <button class="btn btn-secondary" @onclick="OpenFilters" disabled="@true">Filters</button>
        </div>
        <div class="list-main">
            @if (_requests == null) {
                <p>Loading…</p>
            }
            else if (!_requests.Any()) {
                <p>No requests found.</p>
            }
            else {
                <div class="list-scroll-container">
                    <div class="preview-card-list">
                        @foreach (var request in _requests) {
                            <ApplicationRequestPreviewCard Request="request" IsSelected="request == _selectedRequest" OnSelect="SelectRequest"/>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
    <div class="two-column-layout-right">
        <div class="mobile-detail-nav">
            <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="ShowListMobile">
                <span class="bi bi-arrow-left"></span>
                Back to requests
            </button>
        </div>
        <CascadingValue Value="MemberApi" Name="MemberManagementApi" IsFixed="true">
            <ApplicationRequestCard IsEditable="true" Request="_selectedRequest" OnRequestUpdated="Reload" />
        </CascadingValue>  
    </div>
</div>
