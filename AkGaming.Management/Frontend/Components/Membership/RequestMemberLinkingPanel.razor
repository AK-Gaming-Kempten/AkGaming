@using AkGaming.Management.Modules.MemberManagement.Contracts.Enums
<div class="member-form">
    <EditForm Model="@_request" OnValidSubmit="@RequestMemberLinkingAsync">
        <DataAnnotationsValidator />
        <h3> Request member linking </h3>
        <hr class="spacer" />
        <div class="form-grid">
            <div class="form-col">
                <label>First Name</label>
                <InputText @bind-Value="_request.FirstName" required />
                <ValidationMessage For="@(() => _request.FirstName)" />
            </div>

            <div class="form-col">
                <label>Last Name</label>
                <InputText @bind-Value="_request.LastName" required />
                <ValidationMessage For="@(() => _request.LastName)" />
            </div>

            <div class="form-col">
                <label>Email</label>
                <InputText @bind-Value="_request.Email" required />
                <ValidationMessage For="@(() => _request.Email)" />
            </div>

            <div class="form-col">
                <label>Discord Username</label>
                <InputText @bind-Value="_request.DiscordUserName" required />
                <ValidationMessage For="@(() => _request.DiscordUserName)" />
            </div>

            <div class="form-col">
                <label>Reason</label>
                <InputSelect @bind-Value="_request.Reason" required >
                    @foreach (var s in Enum.GetValues<MemberLinkingRequestReason>()) {
                        <option value="@s">@s</option>
                    }
                </InputSelect>
                <ValidationMessage For="@(() => _request.Reason)" />
            </div>
        </div>
        <div class="form-grid">
            <div class="form-col">
                <div class="form-checkbox-with-text">
                    <InputCheckbox @bind-Value="_request.PrivacyPolicyAccepted"/>
                    <label>
                        I accept the <a href="https://akgaming.de/datenschutz" target="_blank" rel="noopener noreferrer">privacy policy</a>.
                    </label>
                </div>
                <ValidationMessage For="@(() => _request.PrivacyPolicyAccepted)"/>
            </div>
        </div>

        <hr class="spacer" />
        <button type="submit" class="btn btn-primary ">Apply</button>
        <p>@_requestError</p>
    </EditForm>
</div>
