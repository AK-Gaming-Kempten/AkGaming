{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "OpenIdConnect": {
    "Authority": "https://localhost:7288",
    "ClientId": "akgaming-management-frontend",
    "ClientSecret": "development-management-client-secret",
    "CallbackPath": "/signin-oidc",
    "SignedOutCallbackPath": "/signout-callback-oidc",
    "RequireHttpsMetadata": true,
    "Scopes": [
      "openid",
      "profile",
      "email",
      "roles",
      "offline_access",
      "management_api"
    ]
  },
  "Api": {
    "BaseUrl": "https://localhost:3014/"
  },
  "IdentityApi": {
    "BaseUrl": "https://localhost:7288",
    "AuditLogPath": "/admin/audit-log"
  },
  "Dev": {
    "AllowUntrustedLocalCertificates": true
  }
}
