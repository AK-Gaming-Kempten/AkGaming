{
  "Logging": {
    "LogLevel": {
      "Microsoft.AspNetCore.Mvc": "Debug",
      "Microsoft.AspNetCore.Http.Json": "Debug",
      "Microsoft.AspNetCore.Routing": "Information",
      "Default": "Information"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Database": {
