{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=management.db"
  },
  "Database": {
    "Provider": "Sqlite"
  },
  "OpenIddictValidation": {
    "Issuer": "https://localhost:7288"
  },
  "Dev": {
    "AllowUntrustedLocalCertificates": true
  },
  "Smtp": {
    "Enabled": false,
    "Host": "smtp.example.com",
    "Port": 587,
    "UseSsl": true,
    "TimeoutSeconds": 15,
    "Username": "smtp-user",
    "Password": "smtp-password",
    "FromEmail": "no-reply@akgaming.de",
    "FromName": "AK Gaming Management (Development)"
  }
}
