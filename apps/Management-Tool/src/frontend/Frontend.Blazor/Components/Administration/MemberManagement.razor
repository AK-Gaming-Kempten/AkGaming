@page "/member-management"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@inject HttpClient Api


<h3>Member Management</h3>

<hr />

<h4>Create New Member</h4>

<EditForm Model="@_newMember" OnValidSubmit="@CreateMemberAsync">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="row">
        <div class="col">
            <InputText @bind-Value="_newMember.FirstName" class="form-control" placeholder="First Name" />
        </div>
        <div class="col">
            <InputText @bind-Value="_newMember.LastName" class="form-control" placeholder="Last Name" />
        </div>
    </div>

    <div class="row mt-2">
        <div class="col">
            <InputText @bind-Value="_newMember.Email" class="form-control" placeholder="Email" />
        </div>
        <div class="col">
            <InputText @bind-Value="_newMember.Phone" class="form-control" placeholder="Phone" />
        </div>
    </div>

    <div class="row mt-2">
        <div class="col">
            <InputText @bind-Value="_newMember.DiscordUserName" class="form-control" placeholder="Discord Username" />
        </div>
        <div class="col">
            <InputDate @bind-Value="_newMember.BirthDate" class="form-control" />
        </div>
    </div>

    <h5 class="mt-3">Address</h5>

    <div class="row">
        <div class="col">
            <InputText @bind-Value="_newMember.Address.Street" class="form-control" placeholder="Street" />
        </div>
        <div class="col">
            <InputText @bind-Value="_newMember.Address.ZipCode" class="form-control" placeholder="Zip Code" />
        </div>
    </div>

    <div class="row mt-2">
        <div class="col">
            <InputText @bind-Value="_newMember.Address.City" class="form-control" placeholder="City" />
        </div>
        <div class="col">
            <InputText @bind-Value="_newMember.Address.Country" class="form-control" placeholder="Country" />
        </div>
    </div>

    <button type="submit" class="btn btn-primary mt-3">Create</button>
</EditForm>

@if (_createError != null)
{
    <p class="text-danger">@_createError</p>
}

<hr />

<h4>Existing Members</h4>

@if (_members == null)
{
    <p>Loading…</p>
}
else if (!_members.Any())
{
    <p>No members found.</p>
}
else
{
    <table class="table">
        <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Status</th>
            <th>Discord</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var m in _members)
        {
            <tr>
                <td>@m.FirstName @m.LastName</td>
                <td>@m.Email</td>
                <td>@m.Status</td>
                <td>@m.DiscordUserName</td>
            </tr>
        }
        </tbody>
    </table>
}