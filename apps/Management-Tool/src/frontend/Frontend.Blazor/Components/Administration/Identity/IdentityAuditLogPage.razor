@page "/identity/audit-log"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]

<PageTitle>Identity Audit Log</PageTitle>

<div class="identity-audit-page card">
    <h4>Identity Audit Log</h4>

    <div class="query-controls">
        <div class="form-col">
            <label for="audit-path">Audit endpoint path</label>
            <InputText id="audit-path" @bind-Value="_auditPath" placeholder="/admin/audit-log" />
        </div>
        <button class="btn btn-secondary" @onclick="LoadAuditLogAsync" disabled="@_isBusy">Load</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <p class="text-danger">@_error</p>
    }

    @if (!string.IsNullOrWhiteSpace(_success))
    {
        <p class="text-success">@_success</p>
    }

    @if (!string.IsNullOrWhiteSpace(_prettyJson))
    {
        <div class="result-meta">@_metaText</div>
        <pre class="json-output">@_prettyJson</pre>
    }
    else
    {
        <p>No audit payload loaded yet.</p>
    }
</div>
