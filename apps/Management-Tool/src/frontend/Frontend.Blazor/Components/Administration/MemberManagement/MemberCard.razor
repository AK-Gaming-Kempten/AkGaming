<div class="member-card container p-3">
    @if (Member is null) {
        <div class="text-muted">Loading member…</div>
    }
    else
    {
        <div class="row">
            <!-- Member fields -->
            <div class="col-md-8 border-end pe-4">
                <div class="row">
                    <div class="w-50">
                        <input class="form-control" @bind="Member.FirstName" placeholder="First name" readonly="@(!EditMode)"/>
                        <input class="form-control mt-2" @bind="Member.LastName" placeholder="Last name" readonly="@(!EditMode)"/>
                        <input class="form-control mt-2" @bind="Member.Email" placeholder="Email" readonly="@(!EditMode)"/>
                        <input class="form-control mt-2" @bind="Member.Phone" placeholder="Phone" readonly="@(!EditMode)"/>
                        <input class="form-control mt-2" @bind="Member.DiscordUserName" placeholder="Discord" readonly="@(!EditMode)"/>
                    </div>
                    <div class="w-50">
                        <h5 class="mt-3">Address</h5>
                        <input class="form-control" @bind="Member.Address.Street" placeholder="Street" readonly="@(!EditMode)"/>
                        <input class="form-control mt-2" @bind="@Member.Address.ZipCode" placeholder="Zip" readonly="@(!EditMode)"/>
                        <input class="form-control mt-2" @bind="Member.Address.City" placeholder="City" readonly="@(!EditMode)"/>
                        <input class="form-control mt-2" @bind="Member.Address.Country" placeholder="Country" readonly="@(!EditMode)"/>
                    </div>
                </div>

                @if (IsEditable)
                {
                    <div class="mt-3">
                        @if (!EditMode)
                        {
                            <button class="btn btn-primary me-2" @onclick="EnableEditing">Edit</button>
                        }
                        else
                        {
                            <button class="btn btn-success me-2" @onclick="SaveChanges">Save</button>
                            <button class="btn btn-secondary" @onclick="CancelChanges">Cancel</button>
                        }
                    </div>
                }
            </div>

            <!-- Status panel -->
            <div class="col-md-4 ps-4">
                <h5>Status History</h5>

                <div class="status-history border p-2 mb-3">
                    @if (_localMember.StatusChanges?.Any() ?? false)
                    {
                        <ul class="list-unstyled">
                            @foreach (var evt in _localMember.StatusChanges.OrderByDescending(e => e.Timestamp))
                            {
                                <li>
                                    <strong>@evt.NewStatus</strong>
                                    <br/>
                                    <small>@evt.Timestamp.ToString("g")</small>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <em>No history available</em>
                    }
                </div>

                @if (EditMode && IsEditable)
                {
                    <StatusUpdateForm OnSubmit="SubmitStatusChange"/>
                }
            </div>
        </div>
    }
</div>
