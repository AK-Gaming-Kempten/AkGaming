<div class="member-card">
    @if (Member is null)
    {
        <div class="text-muted">Loading member…</div>
    }
    else
    {
        <div class="member-card-content">
            <!-- Member fields -->
            <EditForm Model="Member">
                <div class="form-section">
                    <div class="form-grid">
                        <div class="form-col">
                            <label>First name</label>
                            <InputText @bind-Value="Member.FirstName" readonly="@(!EditMode)" />
                        </div>
                        <div class="form-col">
                            <label>Last name</label>
                            <InputText @bind-Value="Member.LastName" readonly="@(!EditMode)" />
                        </div>

                        <div class="form-col">
                            <label>Email</label>
                            <InputText @bind-Value="Member.Email" readonly="@(!EditMode)" />
                        </div>
                        <div class="form-col">
                            <label>Phone</label>
                            <InputText @bind-Value="Member.Phone" readonly="@(!EditMode)" />
                        </div>

                        <div class="form-col">
                            <label>Discord</label>
                            <InputText @bind-Value="Member.DiscordUserName" readonly="@(!EditMode)" />
                        </div>
                        <div class="form-col">
                            <label>Birthdate</label>
                            <InputDate @bind-Value="Member.BirthDate" readonly="@(!EditMode)" />
                        </div>
                    </div>
                </div>

                <div class="form-section">
                    <h5>Address</h5>
                    <div class="form-grid">
                        <div class="form-col">
                            <label>Street</label>
                            <InputText @bind-Value="Member.Address.Street" readonly="@(!EditMode)" />
                        </div>
                        <div class="form-col">
                            <label>ZIP</label>
                            <InputText @bind-Value="Member.Address.ZipCode" readonly="@(!EditMode)" />
                        </div>
                        <div class="form-col">
                            <label>City</label>
                            <InputText @bind-Value="Member.Address.City" readonly="@(!EditMode)" />
                        </div>
                        <div class="form-col">
                            <label>Country</label>
                            <InputText @bind-Value="Member.Address.Country" readonly="@(!EditMode)" />
                        </div>
                    </div>
                </div>
            </EditForm>

            @if (IsEditable)
            {
                <div class="form-actions">
                    @if (!EditMode)
                    {
                        <button class="btn-primary" @onclick="EnableEditing">Edit</button>
                    }
                    else
                    {
                        <button class="btn-success" @onclick="SaveChanges">Save</button>
                        <button class="btn-secondary" @onclick="CancelChanges">Cancel</button>
                    }
                </div>
            }

            <!-- Status panel -->
            <div class="status-section">
                <h5>Status History</h5>

                <div class="status-history scrollable">
                    @if (_localMember.StatusChanges?.Any() ?? false)
                    {
                        <ul class="status-list">
                            @foreach (var evt in _localMember.StatusChanges.OrderByDescending(e => e.Timestamp))
                            {
                                <li>
                                    <strong>@evt.NewStatus</strong><br />
                                    <small>@evt.Timestamp.ToString("g")</small>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <em>No history available</em>
                    }
                </div>

                @if (EditMode && IsEditable)
                {
                    <StatusUpdateForm OnSubmit="SubmitStatusChange" />
                }
            </div>
        </div>
    }
</div>
