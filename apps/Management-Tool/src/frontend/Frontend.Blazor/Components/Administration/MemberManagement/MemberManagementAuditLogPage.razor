@page "/member-management/audit-log"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]

<PageTitle>Member Management Audit Log</PageTitle>

<div class="member-audit-page card">
    <h4>Member Management Audit Log</h4>

    <AuditLogQueryControls Search="@_search"
                           SearchChanged="OnSearchChanged"
                           PageSize="@_pageSize"
                           PageSizeChanged="OnPageSizeChanged"
                           SearchPlaceholder="Search (action, entity, actor, values...)"
                           IsBusy="@_isBusy"
                           OnSearch="SearchAsync"
                           OnRefresh="ReloadAsync" />

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <p class="text-danger">@_error</p>
    }

    @if (!string.IsNullOrWhiteSpace(_success))
    {
        <p class="text-success">@_success</p>
    }

    @if (_auditLogs is null)
    {
        <p>Loading audit logs...</p>
    }
    else if (_auditLogs.Items.Count == 0)
    {
        <p>No audit logs found.</p>
    }
    else
    {
        <div class="table-wrapper">
            <table class="audit-table">
                <thead>
                <tr>
                    <th>Occurred (UTC)</th>
                    <th>Action</th>
                    <th>Performed By</th>
                    <th>Entity</th>
                    <th>Entity Id</th>
                    <th>Old Values</th>
                    <th>New Values</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var item in _auditLogs.Items)
                {
                    <tr>
                        <td>@item.OccurredAtUtc.ToString("u")</td>
                        <td>@item.ActionType</td>
                        <td>@(item.PerformedByUserId?.ToString() ?? "-")</td>
                        <td>@item.EntityType</td>
                        <td>@item.EntityId</td>
                        <td>@(string.IsNullOrWhiteSpace(item.OldValuesJson) ? "-" : item.OldValuesJson)</td>
                        <td>@(string.IsNullOrWhiteSpace(item.NewValuesJson) ? "-" : item.NewValuesJson)</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>

        <AuditLogPager Page="@_page"
                       TotalPages="@_totalPages"
                       TotalCount="@_auditLogs.TotalCount"
                       IsBusy="@_isBusy"
                       OnPrevious="PrevPageAsync"
                       OnNext="NextPageAsync" />
    }
</div>
