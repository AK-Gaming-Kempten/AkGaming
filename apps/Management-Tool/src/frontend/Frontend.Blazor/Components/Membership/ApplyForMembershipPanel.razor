<EditForm Model="@_newMember" OnValidSubmit="@ApplyForMembershipAsync">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="row">
        <div class="col">
            <InputText @bind-Value="_newMember.FirstName" class="form-control" placeholder="First Name" required="true" />
        </div>
        <div class="col">
            <InputText @bind-Value="_newMember.LastName" class="form-control" placeholder="Last Name" required="true" />
        </div>
    </div>

    <div class="row mt-2">
        <div class="col">
            <InputText @bind-Value="_newMember.Email" class="form-control" placeholder="Email" required="true" />
        </div>
        <div class="col">
            <InputText @bind-Value="_newMember.Phone" class="form-control" placeholder="Phone" required="true" />
        </div>
    </div>

    <div class="row mt-2">
        <div class="col">
            <InputText @bind-Value="_newMember.DiscordUserName" class="form-control" placeholder="Discord Username" required="true" />
        </div>
        <div class="col">
            <InputDate @bind-Value="_newMember.BirthDate" class="form-control" required="true" />
        </div>
    </div>

    <h5 class="mt-3">Address</h5>

    <div class="row">
        <div class="col">
            <InputText @bind-Value="_newMember.Address.Street" class="form-control" placeholder="Street / House Number" required="true" />
        </div>
        <div class="col">
            <InputText @bind-Value="_newMember.Address.ZipCode" class="form-control" placeholder="Zip Code" required="true" />
        </div>
    </div>

    <div class="row mt-2">
        <div class="col">
            <InputText @bind-Value="_newMember.Address.City" class="form-control" placeholder="City" required="true" />
        </div>
        <div class="col">
            <InputText @bind-Value="_newMember.Address.Country" class="form-control" placeholder="Country" required="true" />
        </div>
    </div>

    <button type="submit" class="btn btn-primary mt-3">Create</button>
</EditForm>