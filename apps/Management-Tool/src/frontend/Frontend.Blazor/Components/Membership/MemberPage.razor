@page "/membership/user/{UserId}"
<PageTitle>My Membership</PageTitle>
@using Microsoft.AspNetCore.Authorization
@using Frontend.Blazor.Components.Administration.MemberManagement;
@attribute [Authorize]

<PageTitle>My Membership</PageTitle>

<CascadingValue Value="MemberApi" Name="MemberManagementApi" IsFixed="true">
    @if (_loading) {
        <p>Loading...</p>
    }
    else if (_member != null) {
        @if (_applicationRequest != null) {
            <div class="card pending-application-card">
                <h3>Membership Application Pending</h3>
                <p>Thanks for your application! We will review it as soon as possible.</p>
            </div>
        }
        <MemberCard Member="_member" IsEditable="true" IsStatusEditable="false" />
    }
    else {
        <NoMemberPanel UserId="_userGuid" PendingApplication="_applicationRequest" PendingLinkingRequest="_linkingRequest" />
    }
</CascadingValue>
