@page "/account/register"
@model AkGaming.Identity.Api.Pages.Account.RegisterModel
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>AKG Identity | Register</title>
  <link rel="icon" type="image/png" href="/ui/AkGaming_Identity.png" />
  <link rel="stylesheet" href="/ui/akgaming-base-theme.css" />
  <link rel="stylesheet" href="/ui/baseStyles.css" />
  <link rel="stylesheet" href="/ui/styles.css" />
  <script src="/ui/common.js" defer></script>
</head>
<body>
  <main class="shell">
    <div class="topbar">
      <select class="theme-picker" data-theme-picker aria-label="Theme">
        <option value="system">System Theme</option>
        <option value="light">Light Theme</option>
        <option value="dark">Dark Theme</option>
      </select>
    </div>
    <div class="brand">
      <img src="/ui/AkGaming_Identity.png" alt="@ClubConstants.Organization.ShortName" />
      <div class="brand-title">@ClubConstants.Organization.ShortName <span class="identity">Identity</span></div>
    </div>
    <h1>Create Account</h1>
    <p class="sub">Create your local account for @ClubConstants.Organization.ShortName services.</p>

    <form method="post" class="identity-form">
      <input asp-for="ReturnUrl" type="hidden" />

      <div class="ui-field">
        <label asp-for="Email">Email</label>
        <input asp-for="Email" type="email" autocomplete="email" required />
      </div>

      <div class="ui-field">
        <label asp-for="Username">Username</label>
        <input asp-for="Username" type="text" autocomplete="username" maxlength="100" required />
      </div>

      <div class="ui-field">
        <label asp-for="Password">Password</label>
        <input asp-for="Password" type="password" autocomplete="new-password" minlength="8" required />
      </div>

      <label class="checkbox-row">
        <input asp-for="PrivacyPolicyAccepted" type="checkbox" required />
        <span>I have read and accept the <a href="@ClubConstants.Urls.PrivacyPolicy" target="_blank" rel="noopener noreferrer">privacy policy</a>.</span>
      </label>

      <button class="primary" type="submit">Create Account</button>
    </form>

    <a class="button secondary" href="/auth/discord/start?return_url=@Uri.EscapeDataString(Model.ReturnUrl ?? "/account/manage")">Continue with Discord</a>

    <a class="switch" asp-page="/Account/Login" asp-route-returnUrl="@Model.ReturnUrl">Already have an account?</a>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
      <div class="status error">@Model.ErrorMessage</div>
    }
  </main>
</body>
</html>
