@page "/account/register"
@model AkGaming.Identity.Api.Pages.Account.RegisterModel
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>AKG Identity | Register</title>
  <link rel="icon" type="image/png" href="/ui/AkGaming_Identity.png" />
  <link rel="stylesheet" href="/ui/akgaming-base-theme.css" />
  <link rel="stylesheet" href="/ui/baseStyles.css" />
  <link rel="stylesheet" href="/ui/styles.css" />
</head>
<body>
  <main class="shell">
    <div class="brand">
      <img src="/ui/AkGaming_Identity.png" alt="AK Gaming" />
      <div class="brand-title">AK Gaming <span class="identity">Identity</span></div>
    </div>
    <h1>Create Account</h1>
    <p class="sub">Create your local account for AK Gaming services.</p>

    <form method="post">
      <input asp-for="ReturnUrl" type="hidden" />

      <label asp-for="Email">Email</label>
      <input asp-for="Email" type="email" autocomplete="email" required />

      <label asp-for="Password">Password</label>
      <input asp-for="Password" type="password" autocomplete="new-password" minlength="8" required />

      <label class="checkbox-row">
        <input asp-for="PrivacyPolicyAccepted" type="checkbox" required />
        <span>I have read and accept the <a href="https://akgaming.de/datenschutz" target="_blank" rel="noopener noreferrer">privacy policy</a>.</span>
      </label>

      <button class="primary" type="submit">Create Account</button>
    </form>

    <a class="button secondary" href="/auth/discord/start?return_url=@Uri.EscapeDataString(Model.ReturnUrl ?? "/account/manage")">Continue with Discord</a>

    <a class="switch" asp-page="/Account/Login" asp-route-returnUrl="@Model.ReturnUrl">Already have an account?</a>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
      <div class="status error">@Model.ErrorMessage</div>
    }
  </main>
</body>
</html>
