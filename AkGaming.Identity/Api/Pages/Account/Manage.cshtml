@page "/account/manage"
@model AkGaming.Identity.Api.Pages.Account.ManageModel
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>AKG Identity | Account</title>
  <link rel="icon" type="image/png" href="/ui/AkGaming_Identity.png" />
  <link rel="stylesheet" href="/ui/akgaming-base-theme.css" />
  <link rel="stylesheet" href="/ui/baseStyles.css" />
  <link rel="stylesheet" href="/ui/styles.css" />
  <script src="/ui/common.js" defer></script>
</head>
<body>
  <main class="shell shell-wide">
    <div class="topbar">
      <select class="theme-picker" data-theme-picker aria-label="Theme">
        <option value="system">System Theme</option>
        <option value="light">Light Theme</option>
        <option value="dark">Dark Theme</option>
      </select>
    </div>
    <div class="brand">
      <img src="/ui/AkGaming_Identity.png" alt="@ClubConstants.Organization.ShortName" />
      <div class="brand-title">@ClubConstants.Organization.ShortName <span class="identity">Identity</span></div>
    </div>
    <h1>Account</h1>
    <p class="sub">Your local session is active on the Identity server.</p>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
      <div class="status ok">@Model.StatusMessage</div>
    }

    @if (Model.Profile is not null)
    {
      <div class="ui-grid-2">
        <section class="panel">
          <h2>General Info</h2>
          <div class="row"><span class="k">User Id</span><span class="v">@Model.Profile.UserId</span></div>
          <div class="row"><span class="k">Email</span><span class="v">@Model.Profile.Email</span></div>
          <div class="row"><span class="k">Roles</span><span class="v">@string.Join(", ", Model.Profile.Roles)</span></div>
        </section>

        <section class="panel">
          <h2>Login Methods</h2>

          <div class="method-block">
            <div class="method-title">Email / Password</div>
            <div class="row"><span class="k">Email Verified</span><span class="v @(Model.Profile.IsEmailVerified ? "ok" : "warn")">@(Model.Profile.IsEmailVerified ? "Yes" : "No")</span></div>

            @if (!Model.Profile.IsEmailVerified)
            {
              <div class="method-actions">
                <a class="button secondary" asp-page="/Account/Verify" asp-route-returnUrl="/account/manage">Verify Email</a>
              </div>
            }
          </div>

          <div class="method-block">
            <div class="method-title">Discord</div>

            @if (Model.Profile.Discord is null)
            {
              <div class="row"><span class="k">Status</span><span class="v">Not linked</span></div>
            }
            else
            {
              <div class="row"><span class="k">Account</span><span class="v">@(Model.Profile.Discord.ProviderUsername ?? "Discord User")</span></div>
              <div class="row"><span class="k">Discord Id</span><span class="v">@Model.Profile.Discord.ProviderUserId</span></div>
              <div class="row"><span class="k">Linked At</span><span class="v">@Model.Profile.Discord.LinkedAtUtc.ToString("u")</span></div>
            }

            <div class="method-actions">
              <form method="post" asp-page-handler="StartDiscordLink">
                <button class="secondary" type="submit">Link Discord</button>
              </form>
            </div>
          </div>
        </section>
      </div>

      <div class="actions">
        <form method="post" asp-page-handler="Logout">
          <button class="primary" type="submit">Logout</button>
        </form>
      </div>
    }
  </main>
</body>
</html>
