@page "/account/manage"
@model AkGaming.Identity.Api.Pages.Account.ManageModel
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>AKG Identity | Account</title>
  <link rel="icon" type="image/png" href="/ui/AkGaming_Identity.png" />
  <link rel="stylesheet" href="/ui/akgaming-base-theme.css" />
  <link rel="stylesheet" href="/ui/baseStyles.css" />
  <link rel="stylesheet" href="/ui/styles.css" />
</head>
<body>
  <main class="shell shell-wide">
    <div class="brand">
      <img src="/ui/AkGaming_Identity.png" alt="@ClubConstants.Organization.ShortName" />
      <div class="brand-title">@ClubConstants.Organization.ShortName <span class="identity">Identity</span></div>
    </div>
    <h1>Account</h1>
    <p class="sub">Your local session is active on the Identity server.</p>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
      <div class="status ok">@Model.StatusMessage</div>
    }

    @if (Model.Profile is not null)
    {
      <section class="panel">
        <div class="row"><span class="k">User Id</span><span class="v">@Model.Profile.UserId</span></div>
        <div class="row"><span class="k">Email</span><span class="v">@Model.Profile.Email</span></div>
        <div class="row"><span class="k">Roles</span><span class="v">@string.Join(", ", Model.Profile.Roles)</span></div>
        <div class="row"><span class="k">Email Verified</span><span class="v">@Model.Profile.IsEmailVerified</span></div>
        <div class="row"><span class="k">Discord</span><span class="v">@(Model.Profile.Discord is null ? "Not linked" : $"{Model.Profile.Discord.ProviderUsername ?? Model.Profile.Discord.ProviderUserId} ({Model.Profile.Discord.ProviderUserId})")</span></div>
      </section>

      <section class="panel">
        @if (!Model.Profile.IsEmailVerified)
        {
          <a class="button secondary" asp-page="/Account/Verify" asp-route-returnUrl="/account/manage">Verify Email</a>
        }

        <form method="post" asp-page-handler="StartDiscordLink">
          <button class="secondary" type="submit">Link Discord</button>
        </form>

        <form method="post" asp-page-handler="Logout">
          <button class="primary" type="submit">Logout</button>
        </form>
      </section>
    }
  </main>
</body>
</html>
