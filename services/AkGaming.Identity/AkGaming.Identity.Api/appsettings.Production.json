{
  "Database": {
    "Provider": "Postgres"
  },
  "ConnectionStrings": {
    "IdentityDb": "Host=localhost;Port=5432;Database=akgaming_identity;Username=postgres;Password=change-me"
  },
  "Discord": {
    "ClientId": "1447316050642469008",
    "ClientSecret": "your-discord-client-secret",
    "RedirectUri": "https://identity.akgaming.de/auth/discord/callback",
    "Scopes": [ "identify", "email" ],
    "AutoCreateUser": true,
    "RequireManualLinkForExistingEmail": true
  },
  "AuthHardening": {
    "MaxFailedLoginAttempts": 5,
    "LockoutMinutes": 15,
    "RequireVerifiedEmailForLogin": true,
    "EmailVerificationTokenHours": 24,
    "ExposeEmailVerificationToken": false
  }
}
